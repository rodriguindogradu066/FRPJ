<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Catálogo — FRPJSTORE.BR</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:wght@300;400;500;600;700;900&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  /* ── VARIÁVEIS ── */
  :root {
    --black: #0c0c0c;
    --white: #f6f6f2;
    --gray-100: #efefeb;
    --gray-200: #e0e0dc;
    --gray-400: #a8a8a2;
    --gray-600: #5a5a56;
    --border: rgba(0,0,0,0.07);
    --wpp: #25D366;
    --shadow-sm: 0 2px 12px rgba(0,0,0,0.06);
    --shadow-md: 0 8px 32px rgba(0,0,0,0.11);
    --shadow-lg: 0 20px 56px rgba(0,0,0,0.16);
    --radius: 6px;
    --transition: .28s cubic-bezier(.4,0,.2,1);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body {
    font-family: 'Poppins', sans-serif;
    background: var(--white);
    color: var(--black);
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ── CURSOR (desktop) ── */
  @media (pointer: fine) {
    * { cursor: none !important; }
    #cur { position: fixed; width: 8px; height: 8px; background: var(--black); border-radius: 50%; pointer-events: none; z-index: 9999; transform: translate(-50%,-50%); transition: width .18s, height .18s; }
    #cur-r { position: fixed; width: 28px; height: 28px; border: 1.2px solid rgba(0,0,0,.3); border-radius: 50%; pointer-events: none; z-index: 9998; transform: translate(-50%,-50%); transition: all .1s ease; }
  }

  /* ── NAVBAR ── */
  nav {
    position: sticky; top: 0; z-index: 50;
    height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 40px;
    background: rgba(246,246,242,0.94);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow var(--transition);
  }
  nav.scrolled { box-shadow: var(--shadow-sm); }
  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem; letter-spacing: .12em;
    color: var(--black); text-decoration: none;
  }
  .logo span { color: var(--gray-400); }
  .nav-right {
    display: flex; align-items: center; gap: 32px;
  }
  .nav-count {
    font-family: 'Montserrat', sans-serif;
    font-size: .62rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--gray-400);
  }
  .nav-wpp {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: .62rem; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--black); text-decoration: none;
    padding: 8px 18px;
    border: 1.5px solid var(--black);
    border-radius: var(--radius);
    transition: all var(--transition);
  }
  .nav-wpp:hover { background: var(--black); color: var(--white); }
  .nav-wpp svg { flex-shrink: 0; }

  /* ── HERO STRIP ── */
  .hero-strip {
    padding: 64px 40px 48px;
    display: flex; flex-direction: column;
    align-items: flex-start;
    max-width: 900px;
  }
  .hero-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .3em; text-transform: uppercase;
    color: var(--gray-400);
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 18px;
    animation: fadeUp .7s .1s both;
  }
  .hero-tag::before { content: ''; width: 24px; height: 1px; background: var(--gray-400); }
  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.2rem, 7vw, 6rem);
    letter-spacing: .03em; line-height: .92;
    margin-bottom: 18px;
    animation: fadeUp .7s .2s both;
  }
  .hero-sub {
    font-size: .88rem; font-weight: 300;
    color: var(--gray-600); line-height: 1.7;
    max-width: 420px;
    animation: fadeUp .7s .32s both;
  }

  /* ── FILTRO / SEARCH ── */
  .filter-bar {
    padding: 0 40px 40px;
    display: flex; gap: 12px; flex-wrap: wrap;
    align-items: center;
    animation: fadeUp .6s .4s both;
  }
  .filter-btn {
    font-family: 'Montserrat', sans-serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    padding: 8px 18px;
    border: 1.5px solid var(--gray-200);
    border-radius: 100px;
    background: transparent;
    color: var(--gray-600);
    transition: all var(--transition);
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--black);
    border-color: var(--black);
    color: var(--white);
  }
  .search-wrap {
    margin-left: auto;
    position: relative;
  }
  .search-input {
    font-family: 'Poppins', sans-serif;
    font-size: .78rem; font-weight: 400;
    padding: 8px 16px 8px 36px;
    border: 1.5px solid var(--gray-200);
    border-radius: 100px;
    background: transparent;
    color: var(--black);
    outline: none;
    width: 200px;
    transition: border-color var(--transition), width var(--transition);
  }
  .search-input:focus { border-color: var(--black); width: 240px; }
  .search-input::placeholder { color: var(--gray-400); }
  .search-icon {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%);
    color: var(--gray-400); pointer-events: none;
  }

  /* ── GRID ── */
  .catalog-grid {
    padding: 0 40px 100px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  /* ── PRODUCT CARD ── */
  .card {
    background: var(--gray-100);
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    transition: transform var(--transition), box-shadow var(--transition);
    animation: fadeUp .6s both;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  /* Image area */
  .card-img {
    aspect-ratio: 4/5;
    position: relative; overflow: hidden;
    background: var(--gray-200);
    display: flex; align-items: center; justify-content: center;
  }
  .card-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform .5s cubic-bezier(.4,0,.2,1);
    display: block;
  }
  .card-img .img-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px;
    transition: transform .5s cubic-bezier(.4,0,.2,1);
  }
  .card:hover .card-img img,
  .card:hover .img-placeholder { transform: scale(1.04); }

  .placeholder-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: .95rem; letter-spacing: .18em;
    color: rgba(0,0,0,.18); text-align: center;
    padding: 0 16px;
  }

  /* badges */
  .card-badges {
    position: absolute; top: 14px; left: 14px;
    display: flex; gap: 6px; flex-wrap: wrap;
  }
  .badge {
    font-family: 'Montserrat', sans-serif;
    font-size: .52rem; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase;
    padding: 4px 9px; border-radius: 2px;
  }
  .badge-new { background: var(--black); color: var(--white); }
  .badge-exc { background: var(--white); color: var(--black); border: 1px solid var(--border); }
  .badge-lim { background: #e8e4dc; color: var(--gray-600); }

  /* hover overlay */
  .card-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,.32);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity var(--transition);
  }
  .card:hover .card-overlay { opacity: 1; }
  .overlay-btn {
    font-family: 'Montserrat', sans-serif;
    font-size: .62rem; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--black); background: var(--white);
    border: none; padding: 12px 24px; border-radius: var(--radius);
    transform: translateY(8px);
    transition: transform var(--transition), background var(--transition);
  }
  .card:hover .overlay-btn { transform: translateY(0); }
  .overlay-btn:hover { background: var(--gray-100); }

  /* card body */
  .card-body { padding: 20px; }
  .card-name {
    font-family: 'Montserrat', sans-serif;
    font-size: .74rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase;
    color: var(--black); margin-bottom: 6px;
  }
  .card-desc {
    font-size: .78rem; font-weight: 300;
    color: var(--gray-600); line-height: 1.6;
    margin-bottom: 6px;
  }
  .card-tags {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-bottom: 18px; margin-top: 8px;
  }
  .card-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: .52rem; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--gray-400);
    padding: 3px 8px;
    border: 1px solid var(--gray-200);
    border-radius: 100px;
  }
  .card-footer {
    display: flex; align-items: center; justify-content: space-between;
  }
  .card-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.7rem; letter-spacing: .04em;
    line-height: 1;
    color: var(--black);
  }
  .card-price-sub {
    font-size: .62rem; font-weight: 400;
    color: var(--gray-400); font-family: 'Montserrat', sans-serif;
    letter-spacing: .08em;
    display: block; margin-top: 1px;
  }

  /* WhatsApp button */
  .wpp-btn {
    display: flex; align-items: center; gap: 7px;
    font-family: 'Montserrat', sans-serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .16em; text-transform: uppercase;
    color: var(--white);
    background: var(--wpp);
    border: none; padding: 10px 16px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: filter var(--transition), transform var(--transition);
    white-space: nowrap;
  }
  .wpp-btn:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .wpp-btn svg { flex-shrink: 0; }

  /* ── MODAL ── */
  .modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,.55);
    backdrop-filter: blur(6px);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    padding: 24px;
    opacity: 0; pointer-events: none;
    transition: opacity var(--transition);
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--white);
    border-radius: 10px;
    max-width: 720px; width: 100%;
    max-height: 90vh; overflow-y: auto;
    display: grid; grid-template-columns: 1fr 1fr;
    transform: translateY(16px) scale(.98);
    transition: transform var(--transition);
    box-shadow: var(--shadow-lg);
  }
  .modal-overlay.open .modal { transform: translateY(0) scale(1); }
  .modal-img {
    aspect-ratio: 3/4;
    background: var(--gray-200);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; border-radius: 10px 0 0 10px;
  }
  .modal-img img { width: 100%; height: 100%; object-fit: cover; }
  .modal-img .img-placeholder { width:100%; height:100%; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:12px; }
  .modal-content { padding: 40px 36px; display: flex; flex-direction: column; }
  .modal-close {
    align-self: flex-end;
    background: none; border: none;
    color: var(--gray-400); font-size: 1.4rem;
    transition: color var(--transition);
    line-height: 1; padding: 0; margin-bottom: 24px;
  }
  .modal-close:hover { color: var(--black); }
  .modal-badge { margin-bottom: 12px; }
  .modal-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem; letter-spacing: .06em; line-height: 1;
    margin-bottom: 10px;
  }
  .modal-desc {
    font-size: .85rem; font-weight: 300;
    color: var(--gray-600); line-height: 1.75;
    margin-bottom: 20px;
  }
  .modal-specs {
    display: flex; flex-direction: column; gap: 8px;
    padding: 16px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
  }
  .spec-row {
    display: flex; justify-content: space-between;
    font-size: .75rem;
  }
  .spec-key { font-weight: 600; letter-spacing: .08em; text-transform: uppercase; font-family: 'Montserrat', sans-serif; color: var(--gray-400); font-size: .62rem; }
  .spec-val { font-weight: 400; color: var(--black); }
  .modal-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.4rem; letter-spacing: .04em;
    margin-bottom: 20px;
  }
  .modal-wpp {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    font-family: 'Montserrat', sans-serif;
    font-size: .66rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--white);
    background: var(--wpp);
    border: none; padding: 14px 24px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: filter var(--transition), transform var(--transition);
    width: 100%;
  }
  .modal-wpp:hover { filter: brightness(1.07); transform: translateY(-1px); }
  .modal-note {
    margin-top: 12px;
    font-size: .68rem; font-weight: 300;
    color: var(--gray-400); text-align: center; line-height: 1.5;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--black);
    padding: 40px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem; letter-spacing: .12em; color: var(--white); text-decoration: none; }
  .footer-logo span { color: rgba(255,255,255,.3); }
  .footer-social { display: flex; gap: 12px; }
  .footer-link {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px;
    border: 1px solid rgba(255,255,255,.12);
    border-radius: var(--radius);
    color: rgba(255,255,255,.45); text-decoration: none;
    font-size: .95rem;
    transition: all var(--transition);
  }
  .footer-link:hover { border-color: var(--white); color: var(--white); }
  .footer-copy { font-size: .68rem; color: rgba(255,255,255,.28); font-family: 'Montserrat',sans-serif; letter-spacing:.1em; }

  /* ── EMPTY STATE ── */
  .empty {
    grid-column: 1/-1;
    padding: 80px 0; text-align: center;
    color: var(--gray-400);
  }
  .empty-icon { font-size: 2.5rem; margin-bottom: 16px; }
  .empty p { font-size: .88rem; }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    nav { padding: 0 20px; }
    .nav-count { display: none; }
    .hero-strip { padding: 48px 20px 36px; }
    .filter-bar { padding: 0 20px 32px; }
    .catalog-grid { padding: 0 20px 80px; grid-template-columns: 1fr 1fr; gap: 14px; }
    .card-body { padding: 14px; }
    .card-name { font-size: .66rem; }
    .card-desc { font-size: .72rem; }
    .card-price { font-size: 1.4rem; }
    .wpp-btn { font-size: .54rem; padding: 9px 12px; gap: 5px; }
    .wpp-btn span { display: none; }
    .search-wrap { display: none; }
    .modal { grid-template-columns: 1fr; }
    .modal-img { border-radius: 10px 10px 0 0; aspect-ratio: 4/3; }
    .modal-content { padding: 24px 20px; }
    footer { padding: 28px 20px; flex-direction: column; align-items: flex-start; }
  }
</style>
</head>
<body>

<!-- cursor -->
<div id="cur"></div>
<div id="cur-r"></div>

<!-- ── NAVBAR ── -->
<nav id="navbar">
  <a href="#" class="logo">FRPJSTORE<span>.BR</span></a>
  <div class="nav-right">
    <span class="nav-count" id="navCount">— peças</span>
    <a href="https://wa.me/5563992795579" target="_blank" class="nav-wpp">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Falar no WhatsApp
    </a>
  </div>
</nav>

<!-- ── HERO ── -->
<div class="hero-strip">
  <div class="hero-tag">Catálogo Oficial</div>
  <h1 class="hero-title">CAMISETAS<br>STREETWEAR</h1>
  <p class="hero-sub">Escolha sua peça e fale direto com a gente no WhatsApp para confirmar seu pedido.</p>
</div>

<!-- ── FILTRO ── -->
<div class="filter-bar" id="filterBar">
  <button class="filter-btn active" data-filter="all">Todos</button>
  <button class="filter-btn" data-filter="oversized">Oversized</button>
  <button class="filter-btn" data-filter="estampada">Estampada</button>
  <button class="filter-btn" data-filter="basica">Básica</button>
  <button class="filter-btn" data-filter="exclusiva">Exclusiva</button>
  <div class="search-wrap">
    <svg class="search-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input class="search-input" id="searchInput" type="text" placeholder="Buscar modelo...">
  </div>
</div>

<!-- ── GRID ── -->
<div class="catalog-grid" id="catalogGrid"></div>

<!-- ── MODAL ── -->
<div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
  <div class="modal" id="modal">
    <div class="modal-img" id="modalImg"></div>
    <div class="modal-content">
      <button class="modal-close" onclick="closeModalBtn()">✕</button>
      <div class="modal-badge" id="modalBadge"></div>
      <div class="modal-name" id="modalName"></div>
      <div class="modal-desc" id="modalDesc"></div>
      <div class="modal-specs" id="modalSpecs"></div>
      <div class="modal-price" id="modalPrice"></div>
      <a class="modal-wpp" id="modalWpp" href="#" target="_blank">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Tenho interesse nessa peça
      </a>
      <p class="modal-note" id="modalNote"></p>
    </div>
  </div>
</div>

<!-- ── FOOTER ── -->
<footer>
  <a href="#" class="footer-logo">FRPJSTORE<span>.BR</span></a>
  <div class="footer-social">
    <a href="https://www.instagram.com/frpjstore.br/" target="_blank" class="footer-link" title="Instagram">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
    </a>
    <a href="https://wa.me/5563992795579" target="_blank" class="footer-link" title="WhatsApp">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>
  </div>
  <span class="footer-copy">© 2025 FRPJSTORE.BR — Todos os direitos reservados.</span>
</footer>

<script>
// ════════════════════════════════════════════
//  ⚙️  CONFIGURAÇÕES — edite aqui
// ════════════════════════════════════════════

const WHATSAPP_NUMBER = '5563992795579'; // ← Coloque seu número aqui (55 + DDD + número, sem espaços)

// ════════════════════════════════════════════
//  🛍️  PRODUTOS — adicione, edite ou remova
// ════════════════════════════════════════════
const products = [
  {
    id: 1,
    name: 'Essential Oversized',
    description: 'O clássico que nunca sai de moda. Camiseta oversized com caimento perfeito, ideal para qualquer ocasião do dia.',
    price: 129,
    category: 'oversized',
    badges: ['new'],
    image: null, // ← coloque a URL da foto aqui: 'fotos/camiseta1.jpg'
    color: '#d8d8d4',
    specs: {
      'Tecido': '100% Algodão 30.1',
      'Modelagem': 'Oversized',
      'Tamanhos': 'P / M / G / GG',
      'Cuidados': 'Lavar à mão ou máquina fria',
    }
  },
  {
    id: 2,
    name: 'FRPJ Logo Drop',
    description: 'Edição com a identidade da FRPJSTORE em destaque. Estampa exclusiva na frente com tipografia bold.',
    price: 149,
    category: 'estampada',
    badges: ['exclusiva'],
    image: null,
    color: '#c4c4c0',
    specs: {
      'Tecido': '100% Algodão 30.1',
      'Modelagem': 'Oversized',
      'Tamanhos': 'P / M / G / GG',
      'Estampa': 'Serigrafia Premium',
    }
  },
  {
    id: 3,
    name: 'Signature Clean',
    description: 'Minimalismo premium. Sem estampa, sem excessos — apenas o corte e a qualidade falando por si.',
    price: 139,
    category: 'basica',
    badges: [],
    image: null,
    color: '#e0e0dc',
    specs: {
      'Tecido': '100% Algodão Penteado',
      'Modelagem': 'Oversized',
      'Tamanhos': 'P / M / G / GG / XGG',
      'Acabamento': 'Barra dupla ponto corrente',
    }
  },
  {
    id: 4,
    name: 'Dark Tone Oversized',
    description: 'Para quem prefere o lado mais sombrio do streetwear. Cor escura com lavagem especial de fábrica.',
    price: 159,
    category: 'oversized',
    badges: ['lim'],
    image: null,
    color: '#4a4a48',
    specs: {
      'Tecido': '100% Algodão 30.1',
      'Modelagem': 'Oversized pesado',
      'Tamanhos': 'P / M / G / GG',
      'Cor': 'Preto estonado',
    }
  },
  {
    id: 5,
    name: 'Street Gráfica Vol.1',
    description: 'Primeira edição da coleção gráfica da FRPJSTORE. Arte exclusiva desenvolvida para esse drop.',
    price: 169,
    category: 'estampada',
    badges: ['exclusiva', 'lim'],
    image: null,
    color: '#c8c0b8',
    specs: {
      'Tecido': '100% Algodão 30.1',
      'Modelagem': 'Oversized',
      'Tamanhos': 'M / G / GG',
      'Estampa': 'DTF Full Color',
    }
  },
  {
    id: 6,
    name: 'Camo Neutral Drop',
    description: 'Camuflagem em tons neutros que combina com tudo. Um clássico do streetwear com toque premium.',
    price: 155,
    category: 'estampada',
    badges: ['new'],
    image: null,
    color: '#b8b4a8',
    specs: {
      'Tecido': '100% Algodão',
      'Modelagem': 'Oversized',
      'Tamanhos': 'P / M / G / GG',
      'Padrão': 'Camo Neutro Custom',
    }
  },
];

// ════════════════════════════════════════════
//  🔧  ENGINE — não precisa mexer aqui
// ════════════════════════════════════════════

const WPP = WHATSAPP_NUMBER;
const grid = document.getElementById('catalogGrid');
const navCount = document.getElementById('navCount');

const badgeMap = {
  new:       { label: 'Novo', cls: 'badge-new' },
  exclusiva: { label: 'Exclusiva', cls: 'badge-exc' },
  lim:       { label: 'Edição Limitada', cls: 'badge-lim' },
};

function wppLink(product) {
  const msg = encodeURIComponent(
    `Olá! Vi o catálogo da FRPJSTORE.BR e fiquei interessado(a) na camiseta *${product.name}* (R$ ${product.price.toFixed(2).replace('.',',')}). Gostaria de mais informações! 😊`
  );
  return `https://wa.me/${WPP}?text=${msg}`;
}

function buildPlaceholder(product) {
  return `
    <div class="img-placeholder" style="background:${product.color}">
      <svg width="72" height="96" viewBox="0 0 72 96" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 24 Q8 16 36 16 Q64 16 64 24 L67 88 H5 Z" fill="rgba(255,255,255,.18)"/>
        <path d="M8 24 L0 60 H14 L20 28" fill="rgba(255,255,255,.12)"/>
        <path d="M64 24 L72 60 H58 L52 28" fill="rgba(255,255,255,.12)"/>
      </svg>
      <span class="placeholder-label">${product.name}</span>
    </div>`;
}

function renderCards(list) {
  if (!list.length) {
    grid.innerHTML = `<div class="empty"><div class="empty-icon">🔍</div><p>Nenhuma peça encontrada.</p></div>`;
    return;
  }
  grid.innerHTML = list.map((p, i) => `
    <div class="card" style="animation-delay:${i * .07}s" data-id="${p.id}">
      <div class="card-img">
        ${p.image
          ? `<img src="${p.image}" alt="${p.name}" loading="lazy">`
          : buildPlaceholder(p)
        }
        ${p.badges.length ? `<div class="card-badges">${p.badges.map(b=>`<span class="badge ${badgeMap[b].cls}">${badgeMap[b].label}</span>`).join('')}</div>` : ''}
        <div class="card-overlay">
          <button class="overlay-btn" onclick="openModal(${p.id})">Ver detalhes</button>
        </div>
      </div>
      <div class="card-body">
        <div class="card-name">${p.name}</div>
        <div class="card-desc">${p.description}</div>
        <div class="card-tags">
          ${Object.entries(p.specs).slice(0,2).map(([k,v])=>`<span class="card-tag">${v}</span>`).join('')}
        </div>
        <div class="card-footer">
          <div>
            <span class="card-price">R$ ${p.price}</span>
            <span class="card-price-sub">+ frete</span>
          </div>
          <a class="wpp-btn" href="${wppLink(p)}" target="_blank" onclick="event.stopPropagation()">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>Tenho interesse</span>
          </a>
        </div>
      </div>
    </div>
  `).join('');
  navCount.textContent = `${list.length} ${list.length === 1 ? 'peça' : 'peças'}`;
}

// Filter & search
let activeFilter = 'all';
let activeSearch = '';

function applyFilter() {
  let list = products;
  if (activeFilter !== 'all') list = list.filter(p => p.category === activeFilter);
  if (activeSearch) list = list.filter(p =>
    p.name.toLowerCase().includes(activeSearch) ||
    p.description.toLowerCase().includes(activeSearch)
  );
  renderCards(list);
}

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    applyFilter();
  });
});

document.getElementById('searchInput').addEventListener('input', e => {
  activeSearch = e.target.value.toLowerCase().trim();
  applyFilter();
});

// Modal
function openModal(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;

  document.getElementById('modalImg').innerHTML = p.image
    ? `<img src="${p.image}" alt="${p.name}">`
    : buildPlaceholder(p);

  document.getElementById('modalBadge').innerHTML = p.badges.map(b =>
    `<span class="badge ${badgeMap[b].cls}">${badgeMap[b].label}</span>`
  ).join(' ');

  document.getElementById('modalName').textContent = p.name;
  document.getElementById('modalDesc').textContent = p.description;
  document.getElementById('modalPrice').textContent = `R$ ${p.price.toFixed(2).replace('.',',')}`;

  document.getElementById('modalSpecs').innerHTML = Object.entries(p.specs).map(([k,v]) => `
    <div class="spec-row">
      <span class="spec-key">${k}</span>
      <span class="spec-val">${v}</span>
    </div>`).join('');

  document.getElementById('modalWpp').href = wppLink(p);
  document.getElementById('modalNote').textContent =
    `Você será redirecionado(a) para o WhatsApp com a informação sobre "${p.name}" já preenchida.`;

  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModalBtn();
}
function closeModalBtn() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModalBtn(); });

// Navbar scroll
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', scrollY > 20);
});

// Cursor
const cur = document.getElementById('cur');
const curR = document.getElementById('cur-r');
if (cur) {
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; cur.style.left=mx+'px'; cur.style.top=my+'px'; });
  (function loop(){ rx+=(mx-rx)*.1; ry+=(my-ry)*.1; curR.style.left=rx+'px'; curR.style.top=ry+'px'; requestAnimationFrame(loop); })();
}

// Init
renderCards(products);
</script>
</body>
</html>
